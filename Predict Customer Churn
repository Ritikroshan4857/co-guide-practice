re'], bins=[0,12,24,48,72],\n        labels=[0,1,2,3]).astype(int)\n    df['NumServices']     = df[yes_no].sum(axis=1)\n    df['HighValue']       = (df['MonthlyCharges'] > 70).astype(int)\n    df['AtRisk']          = (\n        (df['tenure'] < 12) &\n        (df['Month_contract'] == 1)\n    ).astype(int)\n\n# ── 3 Interaction features ────────────────────\nfor df in [df_train, df_test]:\n    df['ChargePerService'] = (\n        df['MonthlyCharges'] / (df['NumServices'] + 1)\n    )\n    df['TenureContractScore'] = (\n        df['tenure'] * df['Two_yr_contract']\n    )\n    df['RiskScore'] = (\n        df['Month_contract'] +\n        df['Electronic'] +\n        df['Fiber']\n    )\n\n# ── Drop raw categorical columns ──────────────\ndrop_cols = ['Contract','InternetService',\n             'PaymentMethod','MultipleLines']\ndf_train = df_train.drop(drop_cols, axis=1, errors='ignore')\ndf_test  = df_test.drop(drop_cols, axis=1, errors='ignore')\n\n# ── Encode remaining object columns ───────────\nremaining_cats = df_train.select_dtypes(\n    include='object').columns.tolist()\nremaining_cats = [c for c in remaining_cats\n                  if c not in ['Churn']]\n\nfor col in remaining_cats:\n    le = LabelEncoder()\n    combined = pd.concat([\n        df_train[col], df_test[col]\n    ]).astype(str)\n    le.fit(combined)\n    df_train[col] = le.transform(df_train[col].astype(str))\n    df_test[col]  = le.transform(df_test[col].astype(str))\n\n# ── Final check ───────────────────────────────\nprint(\"✅ Pipeline complete!\")\nprint(f\"Train shape : {df_train.shape}\")\nprint(f\"Test shape  : {df_test.shape}\")\nprint(f\"Nulls       : {df_train.isnull().sum().sum()}\")\nprint(f\"Object cols : {df_train.select_dtypes(include='object').columns.tolist()}\")\n\n# Verify interaction features exist\nfor feat in ['Two_yr_contract','Month_contract',\n             'Fiber','ChargePerService',\n             'TenureContractScore','RiskScore']:\n    val = df_train[feat].mean()\n    print(f